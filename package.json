{
  "name": "universal-browser-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local, agent-agnostic Chrome bridge with explicit tab sharing and MCP tools.",
  "license": "MIT",
  "bin": {
    "universal-browser-bridge": "dist/cli.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts serve",
    "serve": "node dist/cli.js serve",
    "mcp": "node dist/cli.js mcp",
    "token": "tsx src/cli.ts token",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "e2e": "npm run build && node scripts/e2e.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.3",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
